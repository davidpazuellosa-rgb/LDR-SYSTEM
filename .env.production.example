# ===== SASI LDR Hub — variáveis de PRODUÇÃO (no VPS) =====
# No servidor, copie para ".env.production" e preencha com os valores reais.
# NUNCA comite este arquivo preenchido.

# Segredo de sessão (gere um novo no VPS com: openssl rand -base64 32)
AUTH_SECRET="COLE_UM_SEGREDO_ALEATORIO_AQUI"
AUTH_URL="https://SEU_SUBDOMINIO_AQUI"

# O banco vive no volume /data (não mude, a menos que saiba o que faz)
DATABASE_URL="file:/data/app.db"

# Usuário admin inicial (troque a senha depois do primeiro login)
SEED_ADMIN_EMAIL="admin@sasi.com"
SEED_ADMIN_PASSWORD="TROQUE_ESTA_SENHA"
SEED_ADMIN_NAME="Administrador SASI"

# Token do HubSpot (pat-...). Cole aqui no servidor — nunca no chat.
HUBSPOT_TOKEN=""

# Opcional: valida se o telefone existe/está ativo via IPQualityScore Phone Validation API.
# Sem essa chave, o sistema valida apenas formato, fonte pública e duplicidade.
IPQS_API_KEY=""

# Subcaminho do nginx (vazio = raiz). Se mudar, rebuilde a imagem.
GROQ_API_KEY=""
GROQ_MODEL="groq/compound-mini"

NEXT_PUBLIC_BASE_PATH=""
