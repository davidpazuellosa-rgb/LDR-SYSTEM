# ===== SASI LDR Hub - variaveis de PRODUCAO =====
# Na Vercel, cadastre estes valores em Project Settings > Environment Variables.
# No VPS, copie para ".env.production" e preencha com os valores reais.
# NUNCA comite este arquivo preenchido.

# Supabase/Postgres
# DATABASE_URL: use a URL com pooler para o app.
# DIRECT_URL: use a URL direta para Prisma migrations/db push.
DATABASE_URL="postgresql://postgres.PROJECT_REF:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:SENHA@db.PROJECT_REF.supabase.co:5432/postgres"

# Segredo de sessao (gere com: openssl rand -base64 32)
AUTH_SECRET="COLE_UM_SEGREDO_ALEATORIO_AQUI"
AUTH_URL="https://sasi-ldr-hub.vercel.app"

# Usuario admin inicial (troque a senha depois do primeiro login)
SEED_ADMIN_EMAIL="admin@sasi.com"
SEED_ADMIN_PASSWORD="TROQUE_ESTA_SENHA"
SEED_ADMIN_NAME="Administrador SASI"

# Token do HubSpot (pat-...). Cole na Vercel ou no servidor.
HUBSPOT_TOKEN=""

# Opcional: valida se o telefone existe/esta ativo via IPQualityScore Phone Validation API.
# Sem essa chave, o sistema valida apenas formato, fonte publica e duplicidade.
IPQS_API_KEY=""

# Subcaminho do nginx (vazio = raiz). Se mudar, rebuilde imagem.
GROQ_API_KEY=""
GROQ_MODEL="groq/compound-mini"
NEXT_PUBLIC_BASE_PATH=""
