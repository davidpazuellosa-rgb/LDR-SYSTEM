# ===== SASI LDR Hub — modelo de variáveis de ambiente =====
# Copie para ".env" e preencha. NÃO comite o .env de verdade.

DATABASE_URL="file:./dev.db"
AUTH_SECRET="troque-por-um-segredo-aleatorio"
AUTH_URL="http://localhost:3000"

SEED_ADMIN_EMAIL="admin@sasi.com"
SEED_ADMIN_PASSWORD="troque-esta-senha"
SEED_ADMIN_NAME="Administrador SASI"

# Private App Token do HubSpot (pat-...). Nunca compartilhe.
HUBSPOT_TOKEN=""

# Opcional: valida se o telefone existe/está ativo via IPQualityScore Phone Validation API.
# Sem essa chave, o sistema valida apenas formato, fonte pública e duplicidade.
IPQS_API_KEY=""

# Subcaminho para publicação no nginx (ex.: "/sasi-ldr"). Vazio = raiz.
GROQ_API_KEY=""
GROQ_MODEL="groq/compound-mini"

NEXT_PUBLIC_BASE_PATH=""
