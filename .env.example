# ===== SASI LDR Hub - modelo de variaveis de ambiente =====
# Copie para ".env" e preencha. NAO comite o .env de verdade.

# Supabase/Postgres
# DATABASE_URL: use a URL com pooler para o app.
# DIRECT_URL: use a URL direta para Prisma migrations/db push.
DATABASE_URL="postgresql://postgres.PROJECT_REF:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:SENHA@db.PROJECT_REF.supabase.co:5432/postgres"

# URL do projeto Supabase (painel → Project Settings → API). Usada pela colaboração
# em tempo real da planilha (Realtime) e pelo backup automático.
NEXT_PUBLIC_SUPABASE_URL=""
# Chave pública (anon/publishable) — só para o Realtime no navegador.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Backup automático diário do banco (cron às 05:00 UTC) → Supabase Storage.
# service_role é SECRETA (Project Settings → API) — nunca no navegador/chat.
# Sem ela, o backup fica desativado (o sistema segue funcionando normalmente).
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BACKUP_BUCKET="backups"
BACKUP_RETENTION_DAYS="14"

# Protege os endpoints /api/cron/* contra chamadas externas (a Vercel injeta o
# header automaticamente nos crons; sem essa variável os crons ficam sem checagem).
CRON_SECRET=""

AUTH_SECRET="troque-por-um-segredo-aleatorio"
AUTH_URL="http://localhost:3000"

SEED_ADMIN_EMAIL="admin@sasi.com"
SEED_ADMIN_PASSWORD="troque-esta-senha"
SEED_ADMIN_NAME="Administrador SASI"

# Envio de convites por e-mail (Resend). Sem isso, o admin copia o link do convite.
# Crie a chave em https://resend.com/api-keys
RESEND_API_KEY=""
# Remetente. Com domínio verificado no Resend use o seu; senão, o de teste do Resend:
EMAIL_FROM="SASI LDR Hub <onboarding@resend.dev>"

# Private App Token do HubSpot (pat-...). Nunca compartilhe.
HUBSPOT_TOKEN=""

# Opcional: valida se o telefone existe/esta ativo via IPQualityScore Phone Validation API.
# Sem essa chave, o sistema valida apenas formato, fonte publica e duplicidade.
IPQS_API_KEY=""

# Subcaminho para publicacao no nginx (ex.: "/sasi-ldr"). Vazio = raiz.
GROQ_API_KEY=""
GROQ_MODEL="groq/compound-mini"
NEXT_PUBLIC_BASE_PATH=""
