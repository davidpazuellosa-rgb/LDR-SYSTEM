// SASI LDR Hub — modelo de dados
// Postgres: usado em producao via Supabase/Vercel e tambem pode ser mantido no VPS.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Usuários do sistema (login/senha)
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("ldr") // admin | ldr
  createdAt    DateTime @default(now())

  createdCorrections  Correction[] @relation("CorrectionCreatedBy")
  resolvedCorrections Correction[] @relation("CorrectionResolvedBy")
  createdContacts     Contact[]    @relation("ContactCreatedBy")
}

// Uma "base" é uma planilha/lote de contatos importado ou criado manualmente
model Base {
  id          String    @id @default(cuid())
  name        String
  description String?
  source      String    @default("manual") // manual | import
  headers     Json      @default("{}")
  createdAt   DateTime  @default(now())
  contacts    Contact[]
}

// Um contato dentro de uma base (uma prefeitura)
model Contact {
  id     String @id @default(cuid())
  baseId String
  base   Base   @relation(fields: [baseId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation("ContactCreatedBy", fields: [createdById], references: [id])

  // Colunas de prefeitura
  cidade             String?
  estado             String?
  regiao             String?
  populacao          String?
  telefonePrefeitura String?
  emailInstitucional String?
  secretariaAdmin    String?
  nomePrefeito       String?
  siteOficial        String?
  whatsapp           String?
  codigoIbge         String?
  origemContato      String?
  faseCicloVida      String?
  campanha           String?
  setor              String?
  departamentos      String?
  solucaoInteresse   String?
  prospectante       String?
  proprietario       String?

  // ok | phone_invalid | corrected | synced
  status    String  @default("ok")
  hubspotId String? // id do contato no HubSpot após sincronizar

  // Formatação por célula (estilo planilha): { campo: { b, i, s, color, bg, align } }
  formats   Json?

  // Exclusão reversível (soft delete): a linha some da tela mas pode ser desfeita.
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  corrections Correction[]
  scans       Scan[]

  @@index([baseId])
  @@index([status])
  @@index([deletedAt])
}

// Fila de correção: cada vez que um telefone é marcado como incorreto,
// nasce uma entrada aqui. O histórico fica preservado mesmo após resolver.
model Scan {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  ok        Boolean
  data      Json?
  error     String?
  summary   String?
  model     String?
  createdAt DateTime @default(now())

  @@index([contactId])
  @@index([createdAt])
}

model Correction {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  field    String  @default("telefonePrefeitura") // telefone geral da prefeitura
  oldValue String?
  newValue String?
  reason   String?
  status   String  @default("pending") // pending | resolved

  createdById  String?
  createdBy    User?   @relation("CorrectionCreatedBy", fields: [createdById], references: [id])
  resolvedById String?
  resolvedBy   User?   @relation("CorrectionResolvedBy", fields: [resolvedById], references: [id])

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([status])
  @@index([contactId])
}

// Metas por LDR (definidas pelo admin), por base e por estado.
// A tabela é criada sob demanda via SQL (ensureMetaTable em src/lib/meta.ts),
// porque o banco de produção não pode ser migrado por fora.
// Quem completou cada linha de contato e quando (produtividade de preenchimento).
// Tabela à parte (criada sob demanda via ensureContactFillTable) para NÃO alterar a
// tabela Contact, que é lida em todo o app — adicionar coluna nela quebraria a produção
// (sem migration no deploy). Existe um registro só enquanto a linha está completa.
model ContactFill {
  contactId       String   @id
  preenchidoPorId String
  concluidoEm     DateTime @default(now())

  @@index([preenchidoPorId])
  @@index([concluidoEm])
}

// Cada LDR tem duas submetas independentes que somam a meta dele:
//  - preenchimento: completar a linha da prefeitura (base + região + estado)
//  - correcao: arrumar contatos errados de uma campanha do HubSpot
// Por isso as dimensões são opcionais: cada linha usa só as do seu "tipo".
model Meta {
  id       String  @id @default(cuid())
  userId   String
  tipo     String  @default("preenchimento") // preenchimento | correcao
  baseId   String? // preenchimento
  regiao   String? // preenchimento
  estado   String? // preenchimento
  campanha String? // correcao
  prazo    String  @default("semanal") // semanal | mensal
  alvo     Int     @default(0) // quantidade da meta no prazo
  criadoEm DateTime @default(now()) // para sinalizar "meta nova" ao LDR

  @@index([userId])
}

// Valores das COLUNAS PERSONALIZADAS (bloco à direita da planilha). As definições
// das colunas (chave + rótulo + ordem) ficam em Base.headers.__cols__; aqui só os
// valores por contato. Tabela criada sob demanda — sem migration na produção.
model ContactCustomValue {
  contactId String
  colKey    String
  valor     String?

  @@id([contactId, colKey])
  @@index([contactId])
}

// Resultado CONGELADO de uma meta num período já encerrado (gravado pelo cron de
// snapshot). O histórico de Minhas Metas usa isto quando existe; senão, recalcula.
// Tabela criada sob demanda (ensureMetaTable) — sem migration na produção.
model MetaSnapshot {
  id            String   @id @default(cuid())
  userId        String
  tipo          String
  baseId        String?
  regiao        String?
  estado        String?
  campanha      String?
  prazo         String
  alvo          Int
  feito         Int
  periodoInicio DateTime
  chave         String   @unique // userId|tipo|base|regiao|estado|campanha|data — idempotência
  criadoEm      DateTime @default(now())

  @@index([userId])
}

// Histórico IMUTÁVEL de ações grandes numa base (importação, substituição…).
// Append-only: cada ação vira um registro com quem fez, quando e um snapshot
// que permite DESFAZER. Tabela criada sob demanda (ensureBaseEventoTable) —
// o banco de produção não roda migration por fora.
model BaseEvento {
  id          String    @id @default(cuid())
  baseId      String
  tipo        String    // import_merge | import_replace
  usuarioId   String?
  usuarioNome String?
  detalhes    Json? // contadores (criados, completados, substituídos…)
  snapshot    Json? // dados para desfazer a ação
  desfeitoEm  DateTime?
  criadoEm    DateTime  @default(now())

  @@index([baseId])
  @@index([criadoEm])
}

// Sugestões de melhoria enviadas pelos usuários (botão flutuante). Só o admin lê,
// na página "Sugestões de Melhoria". Tabela criada sob demanda (ensureSuggestionTable)
// — o banco de produção não roda migration por fora.
model Suggestion {
  id          String   @id @default(cuid())
  usuarioId   String?
  usuarioNome String?
  texto       String // transcrição e/ou texto digitado
  audio       String? // nota de voz em data URL base64 (opcional)
  status      String   @default("nova") // nova | resolvida
  criadoEm    DateTime @default(now())

  @@index([status])
  @@index([criadoEm])
}
