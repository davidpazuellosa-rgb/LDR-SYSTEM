{
  "name": "sasi-ldr-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "sh -c 'node --import tsx --test $(find tests -name \"*.test.ts\" -print)'",
    "verify:metas": "node --env-file=.env --import tsx scripts/verify-metas.ts",
    "backup:sqlite": "node scripts/backup-sqlite.js",
    "repair:history": "node scripts/repair-invalid-history.js",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hubspot/api-client": "^13.5.0",
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.109.0",
    "bcryptjs": "^3.0.3",
    "next": "15.5.19",
    "next-auth": "^5.0.0-beta.31",
    "papaparse": "^5.5.4",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
